    "    movie_count = ('id_x', 'count')\n",
    ").reset_index()\n",
    "\n",
    "# filter for genres with at least 10 movies\n",
    "profit_by_genre = profit_by_genre[profit_by_genre['movie_count'] >= 10]\n",
    "\n",
    "# sort by average profit (most profitable genres first)\n",
    "profit_by_genre = profit_by_genre.sort_values(by='average_profit', ascending=False)\n",
    "\n",
    "# view top 10\n",
    "profit_by_genre.head(10)"
