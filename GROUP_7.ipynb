    "merged_empire['release_date_y'] = pd.to_datetime(merged_empire['release_date_y'], errors='coerce')\n",
    "\n",
    "# Extract month\n",
    "merged_empire['month'] = merged_empire['release_date_y'].dt.month\n",
    "\n",
    "# Function to map month to season\n",
    "def get_season(month):\n",
    "    if month in [12, 1, 2]:\n",
    "        return 'Winter'\n",
    "    elif month in [3, 4, 5]:\n",
    "        return 'Spring'\n",
    "    elif month in [6, 7, 8]:\n",
    "        return 'Summer'\n",
    "    elif month in [9, 10, 11]:\n",
    "        return 'Autumn'\n",
    "\n",
    "# Create season column\n",
    "merged_empire['season'] = merged_empire['month'].apply(get_season)"
   ]
